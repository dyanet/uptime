UPTIME_DOMAINS=/data/domains.txt
UPTIME_INTERVAL=1h
UPTIME_BASELINE=/data/baselines.json
UPTIME_LOG_FILE=/data/uptime.jsonl
UPTIME_SENDER=monitor@example.com
UPTIME_RECIPIENT=ops@example.com
UPTIME_SMTP_HOST=email-smtp.us-east-1.amazonaws.com
UPTIME_SMTP_PORT=587
UPTIME_SMTP_USER=your-smtp-user
UPTIME_SMTP_PASS=your-smtp-password
UPTIME_SMTP_TLS=true
