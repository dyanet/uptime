# --- Shared (monitor + portal) ---
UPTIME_DOMAINS=/data/domains.csv
UPTIME_INTERVAL=1h
UPTIME_BASELINE=/data/baselines.json
UPTIME_LOG_FILE=/data/uptime.jsonl
UPTIME_SENDER=monitor@example.com
UPTIME_RECIPIENT=ops@example.com
UPTIME_SMTP_HOST=email-smtp.us-east-1.amazonaws.com
UPTIME_SMTP_PORT=587
UPTIME_SMTP_USER=your-smtp-user
UPTIME_SMTP_PASS=your-smtp-password
UPTIME_SMTP_TLS=true

# --- Portal only ---
PORTAL_PORT=8080
PORTAL_DOMAIN_FILE=/data/domains.csv
PORTAL_LOG_FILE=/data/uptime.jsonl
PORTAL_HOST=uptime.example.com
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# --- Ghost CMS integration (optional) ---
GHOST_URL=https://your-ghost-site.com
GHOST_ADMIN_KEY=your-key-id:your-key-secret
